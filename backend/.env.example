NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5500

# Firebase Admin SDK (get these from Firebase Console > Project Settings > Service Accounts > Generate New Private Key)
FIREBASE_PROJECT_ID=barangay-portal-15469
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@barangay-portal-15469.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_STORAGE_BUCKET=barangay-portal-15469.firebasestorage.app

# Email (Nodemailer / SendGrid)
EMAIL_FROM=noreply@barangaysirangan.gov.ph
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# Barangay Config
BARANGAY_NAME=Sirangan
BARANGAY_MUNICIPALITY=Sorsogon City
BARANGAY_PROVINCE=Sorsogon
BARANGAY_CODE=SOR
